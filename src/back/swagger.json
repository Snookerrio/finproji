{
  "openapi": "3.0.0",
  "info": {
    "title": "CRM API Full Documentation",
    "version": "1.0.0",
    "description": "Повний опис усіх ендпоінтів CRM: Адмінка, Авторизація та Замовлення"
  },
  "servers": [{ "url": "http://localhost:9000", "description": "Local server" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Вхід у систему",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "admin@gmail.com" },
                  "password": { "type": "string", "example": "admin" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/auth/activate/{token}": {
      "patch": {
        "tags": ["Auth"],
        "summary": "Активація менеджера через токен",
        "parameters": [{ "name": "token", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "password": { "type": "string", "example": "newpass123" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Activated" } }
      }
    },
    "/api/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Отримати всі заявки (з фільтрами)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "name", "in": "query", "schema": { "type": "string" } },
          { "name": "course", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/orders/export": {
      "get": {
        "tags": ["Orders"],
        "summary": "Експорт в Excel",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "File Download" } }
      }
    },
    "/api/orders/groups": {
      "get": {
        "tags": ["Groups"],
        "summary": "Список груп",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } },
        "post": {
          "tags": ["Groups"],
          "summary": "Створити групу",
          "security": [{ "bearerAuth": [] }],
          "requestBody": {
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "name": { "type": "string" } } }
              }
            }
          },
          "responses": { "201": { "description": "Created" } }
        }
      }
    },
    "/api/orders/stats": {
      "get": {
        "tags": ["Orders"],
        "summary": "Статистика заявок",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/orders/{id}": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Редагувати заявку",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/api/orders/{id}/comment": {
      "post": {
        "tags": ["Orders"],
        "summary": "Додати коментар",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object", "properties": { "msg": { "type": "string" } } } } }
        },
        "responses": { "200": { "description": "Comment added" } }
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "Список менеджерів",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } },
        "post": {
          "tags": ["Admin"],
          "summary": "Створити менеджера",
          "security": [{ "bearerAuth": [] }],
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "surname": { "type": "string" },
                    "email": { "type": "string" }
                  }
                }
              }
            }
          },
          "responses": { "201": { "description": "Created" } }
        }
      }
    },
    "/api/admin/users/{id}/re-token": {
      "post": {
        "tags": ["Admin"],
        "summary": "Перевипустити токен активації",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/admin/users/{id}/recovery": {
      "post": {
        "tags": ["Admin"],
        "summary": "Відновлення доступу (новий токен)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/admin/users/{id}/ban": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Забанити менеджера",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Banned" } }
      }
    },
    "/api/admin/users/{id}/unban": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Розбанити менеджера",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Unbanned" } }
      }
    },
    "/api/admin/stats": {
      "get": {
        "tags": ["Admin"],
        "summary": "Статистика адміна",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      }
    }
  }
}