{
  "openapi": "3.0.0",
  "info": {
    "title": "CRM API Full Documentation",
    "version": "1.0.0",
    "description": "Повний опис усіх ендпоінтів CRM: Адмінка, Авторизація, Замовлення та Групи."
  },
  "servers": [{ "url": "http://localhost:9000", "description": "Local server" }],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Вхід у систему",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "admin@gmail.com" },
                  "password": { "type": "string", "example": "admin" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/auth/activate/{token}": {
      "patch": {
        "tags": ["Auth"],
        "summary": "Активація менеджера",
        "parameters": [{ "name": "token", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "password": { "type": "string", "example": "newpass123" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Activated" } }
      }
    },
    "/api/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Отримати заявки з фільтрами",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "name", "in": "query", "schema": { "type": "string" } },
          { "name": "course", "in": "query", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "sortBy", "in": "query", "schema": { "type": "string", "default": "created_at" } },
          { "name": "order", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] } }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/orders/groups": {
      "get": {
        "tags": ["Groups"],
        "summary": "Отримати всі групи",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Groups"],
        "summary": "Створити нову групу",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "name": { "type": "string", "example": "March-2026" } }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/orders/{id}": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Редагувати заявку",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string" },
                  "sum": { "type": "number" },
                  "group": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/api/orders/{id}/comment": {
      "post": {
        "tags": ["Orders"],
        "summary": "Додати коментар",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "text": { "type": "string", "example": "Передзвонити" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Comment added" } }
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "Список менеджерів",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Створити менеджера",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "surname": { "type": "string" },
                  "email": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/admin/users/{id}/ban": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Забанити менеджера",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Banned" } }
      }
    },
    "/api/admin/users/{id}/unban": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Розбанити менеджера",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Unbanned" } }
      }
    },
    "/api/admin/users/{id}/re-token": {
      "post": {
        "tags": ["Admin"],
        "summary": "Перевипустити токен",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/admin/users/{id}/recovery": {
      "post": {
        "tags": ["Admin"],
        "summary": "Відновлення доступу",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/api/admin/stats": {
      "get": {
        "tags": ["Admin"],
        "summary": "Статистика адміна",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Success" } }
      }
    }
  }
}