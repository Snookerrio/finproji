        "type": "text/javascript",
        "exec": [
          "// Скріпт для збереження токена після логіну",
          "if (pm.response.code === 200 && pm.url.includes('login')) {",
          "    var jsonData = pm.response.json();",
          "    pm.environment.set('jwt_token', jsonData.token);",
          "}"
        ]
